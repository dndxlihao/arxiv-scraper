# arXiv论文助手 - 环境变量配置示例

# ============ 应用配置 ============
DEBUG=True
HOST=0.0.0.0
PORT=8000

# ============ 数据库配置 ============
# PostgreSQL数据库连接
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/arxiv_db

# Redis缓存连接
REDIS_URL=redis://localhost:6379/0

# ============ JWT认证配置 ============
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7天
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============ arXiv API配置 ============
ARXIV_API_URL=https://export.arxiv.org/api/query
ARXIV_MAX_RESULTS=100
ARXIV_START_INDEX=0

# ============ 推送通知配置 ============
# Apple Push Notification Service (APNs)
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-team-id
APNS_AUTH_KEY=your-auth-key-file.p8
APNS_TOPIC=com.yourcompany.ArxivReader

# Firebase Cloud Messaging (Android备用)
FCM_SERVER_KEY=your-fcm-server-key

# ============ 邮件配置 ============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@arxiv-reader.app

# ============ 文件存储配置 ============
# AWS S3配置（用于PDF存储）
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=arxiv-paper-assistant

# 本地文件存储
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760  # 10MB

# ============ 监控和分析 ============
# Sentry错误监控
SENTRY_DSN=your-sentry-dsn

# Google Analytics
GA_TRACKING_ID=UA-XXXXXXXXX-X

# ============ 安全配置 ============
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60  # 秒

# ============ 爬虫配置 ============
CRAWL_INTERVAL_HOURS=6
DAILY_SUMMARY_HOUR=8
MAX_PAPERS_PER_USER=50

# ============ 测试配置 ============
TEST_DATABASE_URL=postgresql+asyncpg://test:test@localhost:5432/arxiv_test
TEST_REDIS_URL=redis://localhost:6379/1

# ============ 开发配置 ============
# 设置为True时，跳过某些安全检查
DEVELOPMENT_MODE=False

# ============ 日志配置 ============
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============ 其他配置 ============
APP_NAME=arXiv论文助手
APP_VERSION=1.0.0
CONTACT_EMAIL=support@arxiv-reader.app
SUPPORT_URL=https://github.com/yourusername/arxiv-paper-assistant/issues

# ====================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际情况修改配置
# 3. 生产环境务必修改所有敏感信息
# 4. 不要将 .env 文件提交到版本控制
# ====================================